<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CopilotLauncher.Pages.ShortcutsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CopilotLauncher.Models"
    xmlns:controls="using:CopilotLauncher.Controls"
    FontFamily="{ThemeResource BodyFontFamily}">

    <Grid Padding="{ThemeResource PagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Shortcuts" Style="{StaticResource TitleLargeTextBlockStyle}" FontFamily="{ThemeResource HeadingFontFamily}" FontSize="{ThemeResource PageTitleFontSize}"/>
            <TextBlock Text="One-click reusable shortcuts. Configure them in the New Shortcut tab; they'll appear here."
                       Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}"/>
        </StackPanel>

        <ListView Grid.Row="1"
                  AutomationProperties.AutomationId="ShortcutsList"
                  ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Padding="0"
                  Background="{ThemeResource SubtleFillColorTransparentBrush}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Shortcut">
                    <!-- Card layout: title + path stack on top; action buttons
                         below in a WrapPanel so they wrap to a second row when
                         the card is too narrow to hold them in a single line
                         (which happens in compact mode and on narrow window
                         widths generally). Switching from a Grid (text | buttons)
                         layout fixes the issue where the right-aligned button
                         column compressed the title into a 1-char-wide column. -->
                    <StackPanel Padding="16,14"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="{ThemeResource CardBorderThickness}"
                                CornerRadius="{StaticResource OverlayCornerRadius}"
                                Spacing="10">
                        <TextBlock Text="{x:Bind Label, Mode=OneTime}"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{x:Bind WorkingDirectory, Mode=OneTime}"
                                   Opacity="0.7"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   TextTrimming="CharacterEllipsis"/>
                        <controls:WrapPanel HorizontalSpacing="6" VerticalSpacing="6">
                            <Button Content="▶ Launch"
                                    AutomationProperties.AutomationId="ShortcutLaunchButton"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Tag="{x:Bind Mode=OneTime}"
                                    Click="OnLaunchClick"/>
                            <Button Content="↧ .lnk"
                                    AutomationProperties.AutomationId="ShortcutExportLnkButton"
                                    ToolTipService.ToolTip="Export as Windows shortcut (.lnk)"
                                    Tag="{x:Bind Mode=OneTime}"
                                    Click="OnExportLnkClick"/>
                            <Button Content="🗑"
                                    AutomationProperties.AutomationId="ShortcutDeleteButton"
                                    AutomationProperties.Name="Delete shortcut"
                                    ToolTipService.ToolTip="Delete"
                                    Tag="{x:Bind Mode=OneTime}"
                                    Click="OnDeleteClick"/>
                        </controls:WrapPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2"
                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Padding="12,6">
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.8"/>
        </Border>
    </Grid>
</Page>

