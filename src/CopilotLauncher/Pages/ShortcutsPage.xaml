<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CopilotLauncher.Pages.ShortcutsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CopilotLauncher.Models">

    <Grid Padding="32,24,32,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Shortcuts" Style="{StaticResource TitleLargeTextBlockStyle}"/>
            <TextBlock Text="One-click reusable shortcutes. Configure them in the New Shortcut tab; they'll appear here."
                       Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}"/>
        </StackPanel>

        <ListView Grid.Row="1"
                  AutomationProperties.AutomationId="ShortcutsList"
                  ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Padding="0"
                  Background="{ThemeResource SubtleFillColorTransparentBrush}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Shortcut">
                    <Grid Padding="16,14"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="{ThemeResource CardBorderThickness}"
                          CornerRadius="{StaticResource OverlayCornerRadius}"
                          ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="{x:Bind Label, Mode=OneTime}"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind WorkingDirectory, Mode=OneTime}"
                                       Opacity="0.7"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Button Content="▶ Launch"
                                    AutomationProperties.AutomationId="ShortcutLaunchButton"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Tag="{x:Bind Mode=OneTime}"
                                    Click="OnLaunchClick"/>
                            <Button Content="↧ .lnk"
                                    AutomationProperties.AutomationId="ShortcutExportLnkButton"
                                    ToolTipService.ToolTip="Export as Windows shortcut (.lnk)"
                                    Tag="{x:Bind Mode=OneTime}"
                                    Click="OnExportLnkClick"/>
                            <Button Content="🗑"
                                    AutomationProperties.AutomationId="ShortcutDeleteButton"
                                    AutomationProperties.Name="Delete shortcut"
                                    ToolTipService.ToolTip="Delete"
                                    Tag="{x:Bind Mode=OneTime}"
                                    Click="OnDeleteClick"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2"
                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Padding="12,6">
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.8"/>
        </Border>
    </Grid>
</Page>
