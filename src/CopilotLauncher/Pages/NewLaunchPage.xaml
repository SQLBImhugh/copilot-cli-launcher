<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CopilotLauncher.Pages.NewLaunchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="32,24,32,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="New Launch" Style="{StaticResource TitleLargeTextBlockStyle}"/>
            <TextBlock Text="Build a reusable Copilot CLI launch shortcut. Live preview shows the exact command line that will run."
                       Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14" MaxWidth="720" HorizontalAlignment="Left">

                <!-- Label -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Label" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="Short name for this launch. Becomes the row title in Saved Launches and the .lnk filename if you export one."
                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    <TextBox Text="{x:Bind ViewModel.Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="e.g. FabricPOCPortal"/>
                </StackPanel>

                <!-- Working directory -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Working directory" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="Where Copilot starts when this launch runs. Usually your project root."
                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{x:Bind ViewModel.WorkingDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="C:\code\my-project"/>
                        <Button Grid.Column="1" Content="Browse…" Click="OnBrowseFolderClick"/>
                    </Grid>
                </StackPanel>

                <!-- Resume target -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Resume target" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="Optional. A session name (e.g. 'MyApp-Main') or session id. Empty = fresh session each launch."
                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    <TextBox Text="{x:Bind ViewModel.ResumeTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="(blank for fresh session)"/>
                </StackPanel>

                <!-- Toggles -->
                <StackPanel Spacing="6">
                    <ToggleSwitch Header="AI summary on launch"
                                  OffContent="Off — plain changelog briefing only"
                                  OnContent="On — Copilot writes a contextual summary on version bumps (one premium request)"
                                  IsOn="{x:Bind ViewModel.EnableAISummary, Mode=TwoWay}"/>

                    <ToggleSwitch Header="Pass --allow-all to copilot"
                                  OffContent="Off — confirm each tool call"
                                  OnContent="On — auto-approve every tool call (use with care)"
                                  IsOn="{x:Bind ViewModel.EnableAllowAll, Mode=TwoWay}"/>
                </StackPanel>

                <!-- Extra args -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Extra copilot args" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="Optional. Verbatim flags appended to the copilot command, e.g. '--max-autopilot-continues 100'. Quoted values preserved."
                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    <TextBox Text="{x:Bind ViewModel.ExtraArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="(blank for none)"/>
                </StackPanel>

                <!-- Terminal -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Terminal" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="Override the default terminal from Settings just for this launch."
                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    <ComboBox x:Name="TerminalCombo" SelectionChanged="OnTerminalChanged" MinWidth="320"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Live command preview -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <StackPanel Spacing="4">
                <TextBlock Text="Command preview" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                <TextBlock Text="{x:Bind ViewModel.CommandPreview, Mode=OneWay}"
                           FontFamily="Consolas, 'Cascadia Mono', monospace"
                           TextWrapping="Wrap"
                           IsTextSelectionEnabled="True"/>
            </StackPanel>
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Reset" Click="OnResetClick"/>
            <Button Content="Save" Click="OnSaveClick" IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}"/>
            <Button Content="Save &amp; Launch"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnSaveAndLaunchClick"
                    IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}"/>
        </StackPanel>

        <Border Grid.Row="4"
                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                CornerRadius="6"
                Padding="12,6">
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.8"/>
        </Border>
    </Grid>
</Page>
