<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CopilotLauncher.Pages.SessionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CopilotLauncher.ViewModels"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="32,24,32,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Sessions" Style="{StaticResource TitleLargeTextBlockStyle}"/>
            <TextBlock Text="Resume an existing Copilot session or save it as a launch shortcut."
                       Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}"/>
        </StackPanel>

        <!-- Migration InfoBar (visible only when a legacy install is detected) -->
        <muxc:InfoBar Grid.Row="1"
                      x:Name="MigrationBar"
                      IsOpen="False"
                      Severity="Informational"
                      Title="Legacy PowerShell launcher detected">
            <muxc:InfoBar.ActionButton>
                <Button Content="Import settings" Click="OnImportLegacyClick"/>
            </muxc:InfoBar.ActionButton>
            <muxc:InfoBar.Content>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
                    <Button Content="Skip" Click="OnSkipLegacyClick"/>
                </StackPanel>
            </muxc:InfoBar.Content>
        </muxc:InfoBar>

        <!-- Filter chips + Refresh -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20" VerticalAlignment="Top">
                <StackPanel Spacing="0">
                    <CheckBox Content="Recent (15d)" IsChecked="{x:Bind ViewModel.ShowRecent, Mode=TwoWay}"/>
                    <TextBlock Text="Modified in the last 15 days"
                               Margin="28,-2,0,0" Opacity="0.6"
                               Style="{StaticResource CaptionTextBlockStyle}"/>
                </StackPanel>

                <StackPanel Spacing="0">
                    <CheckBox Content="Named" IsChecked="{x:Bind ViewModel.ShowNamed, Mode=TwoWay}"/>
                    <TextBlock Text="You assigned a name via copilot --name or /rename"
                               Margin="28,-2,0,0" Opacity="0.6"
                               Style="{StaticResource CaptionTextBlockStyle}"/>
                </StackPanel>

                <StackPanel Spacing="0">
                    <CheckBox Content="Heavily used" IsChecked="{x:Bind ViewModel.ShowHeavy, Mode=TwoWay}"/>
                    <TextBlock Text="10+ summary points (long-running session)"
                               Margin="28,-2,0,0" Opacity="0.6"
                               Style="{StaticResource CaptionTextBlockStyle}"/>
                </StackPanel>

                <StackPanel Spacing="0">
                    <CheckBox Content="Show all" IsChecked="{x:Bind ViewModel.ShowAll, Mode=TwoWay}"/>
                    <TextBlock Text="Override above; show every session"
                               Margin="28,-2,0,0" Opacity="0.6"
                               Style="{StaticResource CaptionTextBlockStyle}"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1" Content="↻ Refresh" Click="OnRefreshClick" VerticalAlignment="Top"/>
        </Grid>

        <!-- Search + Sort row -->
        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox Grid.Column="0"
                            QueryIcon="Find"
                            PlaceholderText="Filter by path, repo, branch, or session id…"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Column="1" Text="Sort by:" VerticalAlignment="Center" Opacity="0.7"/>

            <ComboBox Grid.Column="2" x:Name="SortCombo" SelectionChanged="OnSortChanged" MinWidth="160">
                <ComboBoxItem Tag="LastModified" Content="Last modified" IsSelected="True"/>
                <ComboBoxItem Tag="Name"         Content="Name"/>
                <ComboBoxItem Tag="Cwd"          Content="Working directory"/>
                <ComboBoxItem Tag="Repository"   Content="Repository"/>
                <ComboBoxItem Tag="SummaryCount" Content="Summary count"/>
                <ComboBoxItem Tag="Size"         Content="Size on disk"/>
            </ComboBox>

            <Button Grid.Column="3" Click="OnToggleSortDirection"
                    ToolTipService.ToolTip="Reverse sort order">
                <FontIcon x:Name="SortDirectionGlyph" Glyph="&#xE74B;" FontSize="14"/>
            </Button>
        </Grid>

        <!-- Session list -->
        <ListView Grid.Row="4"
                  ItemsSource="{x:Bind ViewModel.Visible, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Padding="0"
                  Background="Transparent">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:SessionRow">
                    <Grid Padding="16,14"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <!-- User-named session: bold subtitle -->
                            <TextBlock Text="{x:Bind Title}"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind HasUserName, Converter={StaticResource BoolToVisibility}}"/>

                            <!-- Auto-generated name: regular weight, muted (secondary) text color
                                 with caption underneath; the muted color signals "unofficial". -->
                            <TextBlock Text="{x:Bind Title}"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       FontWeight="Normal"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind HasAutoName, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{x:Bind AutoNameDescription}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Opacity="0.55"
                                       FontStyle="Italic"
                                       Margin="0,-2,0,0"
                                       Visibility="{x:Bind HasAutoName, Converter={StaticResource BoolToVisibility}}"/>

                            <TextBlock Text="{x:Bind Cwd}"
                                       Opacity="{x:Bind CwdOpacity}"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind RepoBranch}"
                                       Opacity="0.7"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind Tags}"
                                       Opacity="0.7"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind LastOpenedDisplay}"
                                       Opacity="0.5"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button Content="▶ Resume"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Tag="{x:Bind}"
                                    Click="OnResumeClick"
                                    HorizontalAlignment="Stretch"/>
                            <Button Content="Save as shortcut…"
                                    Tag="{x:Bind}"
                                    Click="OnSaveAsLaunchClick"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status bar -->
        <Border Grid.Row="5"
                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                CornerRadius="6"
                Padding="12,6">
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.8"/>
        </Border>
    </Grid>
</Page>
