<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CopilotLauncher.Pages.SessionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CopilotLauncher.ViewModels">

    <Grid Padding="32,24,32,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Sessions" Style="{StaticResource TitleLargeTextBlockStyle}"/>
            <TextBlock Text="Resume an existing Copilot session or save it as a launch shortcut."
                       Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}"/>
        </StackPanel>

        <!-- Filter chips + Refresh -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <CheckBox x:Name="ChipRecent" Content="Recent (15d)" IsChecked="{x:Bind ViewModel.ShowRecent, Mode=TwoWay}"/>
                <CheckBox x:Name="ChipNamed"  Content="All named"   IsChecked="{x:Bind ViewModel.ShowNamed, Mode=TwoWay}"/>
                <CheckBox x:Name="ChipHeavy"  Content="Heavily used" IsChecked="{x:Bind ViewModel.ShowHeavy, Mode=TwoWay}"/>
                <CheckBox x:Name="ChipAll"    Content="Show all"    IsChecked="{x:Bind ViewModel.ShowAll, Mode=TwoWay}"/>
            </StackPanel>

            <Button Grid.Column="1" Content="↻ Refresh" Click="OnRefreshClick"/>
        </Grid>

        <!-- Search -->
        <AutoSuggestBox Grid.Row="2"
                        QueryIcon="Find"
                        PlaceholderText="Filter by path, repo, branch, or session id…"
                        Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Session list -->
        <ListView Grid.Row="3"
                  ItemsSource="{x:Bind ViewModel.Visible, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Padding="0"
                  Background="Transparent">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:SessionRow">
                    <Grid Padding="16,14"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="{x:Bind Cwd}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind RepoBranch}"
                                       Opacity="0.7"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind Tags}"
                                       Opacity="0.7"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind LastOpenedDisplay}"
                                       Opacity="0.5"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="▶ Resume"
                                Style="{StaticResource AccentButtonStyle}"
                                VerticalAlignment="Center"
                                Tag="{x:Bind}"
                                Click="OnResumeClick"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                CornerRadius="6"
                Padding="12,6">
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.8"/>
        </Border>
    </Grid>
</Page>
