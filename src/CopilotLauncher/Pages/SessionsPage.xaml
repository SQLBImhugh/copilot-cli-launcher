<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CopilotLauncher.Pages.SessionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CopilotLauncher.ViewModels"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:controls="using:CopilotLauncher.Controls"
    xmlns:local="using:CopilotLauncher.Pages">

    <Grid Padding="32,24,32,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Sessions" Style="{StaticResource TitleLargeTextBlockStyle}" FontFamily="{ThemeResource HeadingFontFamily}"/>
            <TextBlock Text="Resume an existing Copilot session or save it as a launch shortcut."
                       Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}"/>
        </StackPanel>

        <!-- Migration InfoBar (visible only when a legacy install is detected) -->
        <muxc:InfoBar Grid.Row="1"
                      x:Name="MigrationBar"
                      AutomationProperties.AutomationId="SessionsMigrationInfoBar"
                      IsOpen="False"
                      Severity="Informational"
                      Title="Legacy PowerShell launcher detected">
            <muxc:InfoBar.ActionButton>
                <Button Content="Import settings"
                        AutomationProperties.AutomationId="MigrationImportButton"
                        Click="OnImportLegacyClick"/>
            </muxc:InfoBar.ActionButton>
            <muxc:InfoBar.Content>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
                    <Button Content="Skip"
                            AutomationProperties.AutomationId="MigrationSkipButton"
                            Click="OnSkipLegacyClick"/>
                </StackPanel>
            </muxc:InfoBar.Content>
        </muxc:InfoBar>

        <!-- Filter chips + Refresh -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- WrapPanel flows left-to-right and breaks to a new row when
                 the next filter cell would overflow. Filter descriptions live
                 in tooltips (hover the checkbox) instead of inline captions
                 so the row stays compact and the cells don't wrap their
                 captions across multiple lines. -->
            <controls:WrapPanel Grid.Column="0"
                                HorizontalSpacing="24"
                                VerticalSpacing="8"
                                VerticalAlignment="Top">
                <CheckBox Content="Recent (15d)"
                          AutomationProperties.AutomationId="SessionsFilterRecent"
                          FontSize="{ThemeResource FilterCheckBoxFontSize}"
                          ToolTipService.ToolTip="Modified in the last 15 days"
                          IsChecked="{x:Bind ViewModel.ShowRecent, Mode=TwoWay}"/>

                <CheckBox Content="Named"
                          AutomationProperties.AutomationId="SessionsFilterNamed"
                          FontSize="{ThemeResource FilterCheckBoxFontSize}"
                          ToolTipService.ToolTip="You assigned a name via copilot --name or /rename"
                          IsChecked="{x:Bind ViewModel.ShowNamed, Mode=TwoWay}"/>

                <CheckBox Content="Heavily used"
                          AutomationProperties.AutomationId="SessionsFilterHeavy"
                          FontSize="{ThemeResource FilterCheckBoxFontSize}"
                          ToolTipService.ToolTip="10+ summary points (long-running session)"
                          IsChecked="{x:Bind ViewModel.ShowHeavy, Mode=TwoWay}"/>

                <CheckBox Content="Show all"
                          AutomationProperties.AutomationId="SessionsFilterShowAll"
                          FontSize="{ThemeResource FilterCheckBoxFontSize}"
                          ToolTipService.ToolTip="Override above; show every session"
                          IsChecked="{x:Bind ViewModel.ShowAll, Mode=TwoWay}"/>
            </controls:WrapPanel>

            <Button Grid.Column="1"
                    Content="↻ Refresh"
                    AutomationProperties.AutomationId="SessionsRefreshButton"
                    Click="OnRefreshClick"
                    VerticalAlignment="Top"/>
        </Grid>

        <!-- Search + Sort row -->
        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox Grid.Column="0"
                            AutomationProperties.AutomationId="SessionsSearchBox"
                            QueryIcon="Find"
                            PlaceholderText="Filter by path, repo, branch, or session id…"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Column="1" Text="Sort by:" VerticalAlignment="Center" Opacity="0.7"/>

            <ComboBox Grid.Column="2"
                      x:Name="SortCombo"
                      AutomationProperties.AutomationId="SessionsSortCombo"
                      SelectionChanged="OnSortChanged"
                      MinWidth="160">
                <ComboBoxItem Tag="LastModified" Content="Last modified" IsSelected="True"/>
                <ComboBoxItem Tag="Name"         Content="Name"/>
                <ComboBoxItem Tag="Cwd"          Content="Working directory"/>
                <ComboBoxItem Tag="Repository"   Content="Repository"/>
                <ComboBoxItem Tag="SummaryCount" Content="Summary count"/>
                <ComboBoxItem Tag="Size"         Content="Size on disk"/>
            </ComboBox>

            <Button Grid.Column="3"
                    AutomationProperties.AutomationId="SessionsSortDirectionButton"
                    AutomationProperties.Name="Toggle sort direction"
                    Click="OnToggleSortDirection"
                    ToolTipService.ToolTip="Reverse sort order">
                <FontIcon x:Name="SortDirectionGlyph" Glyph="&#xE74B;" FontSize="14"/>
            </Button>
        </Grid>

        <!-- Session list -->
        <ListView Grid.Row="4"
                  AutomationProperties.AutomationId="SessionsList"
                  ItemsSource="{x:Bind ViewModel.Visible, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Padding="0"
                  Background="{ThemeResource SubtleFillColorTransparentBrush}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:SessionRow">
                    <Grid Padding="16,14"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="{ThemeResource CardBorderThickness}"
                          CornerRadius="{StaticResource OverlayCornerRadius}"
                          ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <!-- User-named session: bold subtitle -->
                            <TextBlock Text="{x:Bind Title, Mode=OneTime}"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind local:SessionsPage.BoolToVisibility(HasUserName), Mode=OneTime}"/>

                            <!-- Auto-generated name: regular weight, muted (secondary) text color
                                 with caption underneath; the muted color signals "unofficial". -->
                            <TextBlock Text="{x:Bind Title, Mode=OneTime}"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       FontWeight="Normal"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind local:SessionsPage.BoolToVisibility(HasAutoName), Mode=OneTime}"/>
                            <TextBlock Text="{x:Bind AutoNameDescription, Mode=OneTime}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Opacity="0.55"
                                       FontStyle="Italic"
                                       Margin="0,-2,0,0"
                                       Visibility="{x:Bind local:SessionsPage.BoolToVisibility(HasAutoName), Mode=OneTime}"/>

                            <TextBlock Text="{x:Bind Cwd, Mode=OneTime}"
                                       Opacity="{x:Bind CwdOpacity, Mode=OneTime}"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind RepoBranch, Mode=OneTime}"
                                       Opacity="0.7"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind Tags, Mode=OneTime}"
                                       Opacity="0.7"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind LastOpenedDisplay, Mode=OneTime}"
                                       Opacity="0.5"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button Content="▶ Resume"
                                    AutomationProperties.AutomationId="SessionResumeButton"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Tag="{x:Bind Mode=OneTime}"
                                    Click="OnResumeClick"
                                    HorizontalAlignment="Stretch"/>
                            <Button Content="Save as shortcut…"
                                    AutomationProperties.AutomationId="SessionSaveAsShortcutButton"
                                    Tag="{x:Bind Mode=OneTime}"
                                    Click="OnSaveAsLaunchClick"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status bar -->
        <Border Grid.Row="5"
                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Padding="12,6">
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.8"/>
        </Border>
    </Grid>
</Page>
