<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CopilotLauncher.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="32,24" Spacing="16">
            <TextBlock Text="Settings" Style="{StaticResource TitleLargeTextBlockStyle}"/>
            <TextBlock Text="Phase 0 ships Storage, About, and the Default Terminal picker. The remaining setting groups (Briefings, Session listing, Launcher behavior, Repair) land in their respective phases."
                       Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap"/>

            <!-- Terminal -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Terminal" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Default terminal that wraps copilot when you click Resume." Opacity="0.7" Style="{StaticResource CaptionTextBlockStyle}"/>
                    <ComboBox x:Name="TerminalCombo" SelectionChanged="OnTerminalSelectionChanged" MinWidth="280"/>
                    <TextBlock x:Name="TerminalDetail" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <!-- Storage -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Storage" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock x:Name="AppDataPathLabel" Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap"/>
                    <Button Content="Open app data folder" Click="OnOpenAppDataClick"/>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="About" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock x:Name="VersionLabel" Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}"/>
                    <TextBlock Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}">
                        <Hyperlink NavigateUri="https://github.com/SQLBImhugh/copilot-cli-launcher">Source on GitHub</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
