<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CopilotLauncher.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    FontFamily="{ThemeResource BodyFontFamily}">
    <ScrollViewer>
        <StackPanel Padding="{ThemeResource PagePadding}" Spacing="14" MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{StaticResource TitleLargeTextBlockStyle}" FontFamily="{ThemeResource HeadingFontFamily}" FontSize="{ThemeResource PageTitleFontSize}"/>

            <!-- Terminal -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="{ThemeResource CardBorderThickness}" CornerRadius="{StaticResource OverlayCornerRadius}" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Terminal" Style="{StaticResource SubtitleTextBlockStyle}" FontFamily="{ThemeResource HeadingFontFamily}" FontSize="{ThemeResource SectionTitleFontSize}"/>
                    <TextBlock Text="The terminal that wraps copilot when you click Resume or Launch."
                               Opacity="0.7" Style="{StaticResource CaptionTextBlockStyle}"/>
                    <ComboBox x:Name="TerminalCombo"
                              AutomationProperties.AutomationId="SettingsTerminalCombo"
                              SelectionChanged="OnTerminalSelectionChanged"
                              MinWidth="320"/>
                    <TextBlock x:Name="TerminalDetail" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <!-- Sessions Resume defaults -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="{ThemeResource CardBorderThickness}" CornerRadius="{StaticResource OverlayCornerRadius}" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Sessions Resume defaults" Style="{StaticResource SubtitleTextBlockStyle}" FontFamily="{ThemeResource HeadingFontFamily}" FontSize="{ThemeResource SectionTitleFontSize}"/>
                    <TextBlock Text="Used when you click ▶ Resume on a session card. Saved Shortcuts use their own per-shortcut config instead."
                               Opacity="0.7" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>
                    <ToggleSwitch Header="AI summary on resume"
                                  AutomationProperties.AutomationId="SettingsResumeAISummaryToggle"
                                  IsOn="{x:Bind ViewModel.ResumeAISummary, Mode=TwoWay}"/>
                    <ToggleSwitch Header="Pass --allow-all"
                                  AutomationProperties.AutomationId="SettingsResumeAllowAllToggle"
                                  IsOn="{x:Bind ViewModel.ResumeAllowAll, Mode=TwoWay}"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Extra copilot args"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="e.g. --max-autopilot-continues 100"
                                   Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBox AutomationProperties.AutomationId="SettingsResumeExtraArgsTextBox"
                                 Text="{x:Bind ViewModel.ResumeExtraArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- AI Summary -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="{ThemeResource CardBorderThickness}" CornerRadius="{StaticResource OverlayCornerRadius}" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="AI Summary" Style="{StaticResource SubtitleTextBlockStyle}" FontFamily="{ThemeResource HeadingFontFamily}" FontSize="{ThemeResource SectionTitleFontSize}"/>
                    <TextBlock Text="Default agents.md context file used to tailor Copilot's summary on version bumps. Each Shortcut can override this with its own context file."
                               Opacity="0.7" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>
                    <ToggleSwitch Header="Generate AI summary on version bump"
                                  AutomationProperties.AutomationId="SettingsAISummaryOnBumpToggle"
                                  IsOn="{x:Bind ViewModel.AISummaryOnBump, Mode=TwoWay}"/>
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Header="Default agents.md path"
                                 AutomationProperties.AutomationId="SettingsAgentsContextFilePathTextBox"
                                 Text="{x:Bind ViewModel.AgentsContextFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="(none — bundled default will be used)"/>
                        <Button Grid.Column="1"
                                Content="Browse…"
                                AutomationProperties.AutomationId="SettingsBrowseAgentsButton"
                                VerticalAlignment="Bottom"
                                Click="OnBrowseAgentsClick"/>
                    </Grid>
                    <TextBox Header="Briefing session name (for historical context)"
                             AutomationProperties.AutomationId="SettingsBriefingSessionNameTextBox"
                             Text="{x:Bind ViewModel.BriefingSessionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="(empty — each briefing is stateless)"/>
                    <TextBlock Text="When set, briefings reuse the named Copilot CLI session so the AI has cumulative context across version bumps. Created on first run, resumed thereafter. Leave empty for one-shot summaries."
                               Opacity="0.7" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Briefings -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="{ThemeResource CardBorderThickness}" CornerRadius="{StaticResource OverlayCornerRadius}" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Briefings" Style="{StaticResource SubtitleTextBlockStyle}" FontFamily="{ThemeResource HeadingFontFamily}" FontSize="{ThemeResource SectionTitleFontSize}"/>
                    <ToggleSwitch Header="Show briefing on Copilot CLI version bumps"
                                  AutomationProperties.AutomationId="SettingsShowVersionBumpBriefingToggle"
                                  IsOn="{x:Bind ViewModel.ShowVersionBumpBriefing, Mode=TwoWay}"/>
                    <ToggleSwitch Header="Append to rolling briefing-history.log"
                                  AutomationProperties.AutomationId="SettingsAppendToHistoryLogToggle"
                                  IsOn="{x:Bind ViewModel.AppendToHistoryLog, Mode=TwoWay}"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Auto-update frequency" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <ComboBox x:Name="UpdateFreqCombo"
                                  AutomationProperties.AutomationId="SettingsAutoUpdateFreqCombo"
                                  SelectionChanged="OnUpdateFreqChanged"
                                  MinWidth="220">
                            <ComboBoxItem Tag="everyLaunch" Content="Every launch"/>
                            <ComboBoxItem Tag="daily" Content="Once per day"/>
                            <ComboBoxItem Tag="weekly" Content="Once per week"/>
                            <ComboBoxItem Tag="manual" Content="Manual only (Briefing tab → Check now)"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Session listing -->
            <muxc:Expander Header="Session listing"
                           AutomationProperties.AutomationId="SettingsSessionListingExpander"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Stretch"
                           CornerRadius="{StaticResource OverlayCornerRadius}">
                <StackPanel Spacing="10" Padding="8,4">
                    <TextBlock Text="How sessions on the Sessions tab are filtered + grouped."
                               Opacity="0.7" Style="{StaticResource CaptionTextBlockStyle}"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Recent window (days)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <Slider x:Name="RecentSlider"
                                AutomationProperties.AutomationId="SettingsRecentWindowSlider"
                                Minimum="1"
                                Maximum="90"
                                StepFrequency="1"
                                Value="{x:Bind ViewModel.RecentWindowDays, Mode=TwoWay}"
                                ValueChanged="OnSliderChanged"/>
                        <TextBlock Text="{x:Bind ViewModel.RecentWindowDays, Mode=OneWay}" Opacity="0.6"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Heavily-used threshold (summary count)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <Slider x:Name="HeavySlider"
                                AutomationProperties.AutomationId="SettingsHeavyThresholdSlider"
                                Minimum="1"
                                Maximum="200"
                                StepFrequency="1"
                                Value="{x:Bind ViewModel.HeavyUseSummaryThreshold, Mode=TwoWay}"
                                ValueChanged="OnSliderChanged"/>
                        <TextBlock Text="{x:Bind ViewModel.HeavyUseSummaryThreshold, Mode=OneWay}" Opacity="0.6"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                    <ToggleSwitch Header="Show full session id (instead of truncated to 8 chars)"
                                  AutomationProperties.AutomationId="SettingsShowFullSessionIdToggle"
                                  IsOn="{x:Bind ViewModel.ShowFullSessionId, Mode=TwoWay}"/>
                </StackPanel>
            </muxc:Expander>

            <!-- Repair & workarounds -->
            <muxc:Expander Header="Repair &amp; workarounds"
                           AutomationProperties.AutomationId="SettingsRepairWorkaroundsExpander"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Stretch"
                           CornerRadius="{StaticResource OverlayCornerRadius}">
                <StackPanel Spacing="10" Padding="8,4">
                    <ToggleSwitch Header="Auto-repair dangling tool_use events on app start"
                                  AutomationProperties.AutomationId="SettingsAutoRepairDanglingToggle"
                                  OffContent="Off — sessions with interrupted tool calls may fail on --resume"
                                  OnContent="On — silently fix dangling events at startup (default, recommended)"
                                  IsOn="{x:Bind ViewModel.AutoRepairDanglingToolUse, Mode=TwoWay}"/>
                </StackPanel>
            </muxc:Expander>

            <!-- Launcher behavior -->
            <muxc:Expander Header="Launcher behavior"
                           AutomationProperties.AutomationId="SettingsLauncherBehaviorExpander"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Stretch"
                           CornerRadius="{StaticResource OverlayCornerRadius}">
                <StackPanel Spacing="10" Padding="8,4">
                    <StackPanel Spacing="4">
                        <TextBlock Text="After launching a session" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <ComboBox x:Name="AfterLaunchCombo"
                                  AutomationProperties.AutomationId="SettingsAfterLaunchCombo"
                                  SelectionChanged="OnAfterLaunchChanged"
                                  MinWidth="220">
                            <ComboBoxItem Tag="stayOpen" Content="Stay open"/>
                            <ComboBoxItem Tag="minimize" Content="Minimize to taskbar"/>
                            <ComboBoxItem Tag="hideToTray" Content="Hide to system tray"/>
                            <ComboBoxItem Tag="close" Content="Close"/>
                        </ComboBox>
                    </StackPanel>
                    <ToggleSwitch Header="Start with Windows"
                                  AutomationProperties.AutomationId="SettingsStartWithWindowsToggle"
                                  IsOn="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Theme" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <ComboBox x:Name="ThemeCombo"
                                  AutomationProperties.AutomationId="SettingsThemeCombo"
                                  SelectionChanged="OnThemeChanged"
                                  MinWidth="220">
                            <ComboBoxItem Tag="system" Content="Follow system"/>
                            <ComboBoxItem Tag="light" Content="Light"/>
                            <ComboBoxItem Tag="dark" Content="Dark"/>
                            <ComboBoxItem Tag="copilotCli" Content="Copilot CLI (cyan / pink / dark)"/>
                        </ComboBox>
                        <TextBlock Text="Copilot CLI palette: cyan #0099CC, pink #CC66CC, green #30C868 — sampled from the GitHub Copilot CLI welcome banner."
                                   Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </muxc:Expander>

            <!-- Storage -->
            <muxc:Expander Header="Storage"
                           AutomationProperties.AutomationId="SettingsStorageExpander"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Stretch"
                           CornerRadius="{StaticResource OverlayCornerRadius}">
                <StackPanel Spacing="8" Padding="8,4">
                    <TextBlock x:Name="AppDataPathLabel" Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap"/>
                    <Button Content="Open app data folder"
                            AutomationProperties.AutomationId="SettingsOpenAppDataButton"
                            Click="OnOpenAppDataClick"/>
                </StackPanel>
            </muxc:Expander>

            <!-- About -->
            <muxc:Expander Header="About"
                           AutomationProperties.AutomationId="SettingsAboutExpander"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Stretch"
                           CornerRadius="{StaticResource OverlayCornerRadius}">
                <StackPanel Spacing="6" Padding="8,4">
                    <TextBlock x:Name="VersionLabel" Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}"/>
                    <TextBlock Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}">
                        <Hyperlink AutomationProperties.AutomationId="SettingsSourceLinkHyperlink"
                                   NavigateUri="https://github.com/SQLBImhugh/copilot-cli-launcher">Source on GitHub</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </muxc:Expander>
        </StackPanel>
    </ScrollViewer>
</Page>
