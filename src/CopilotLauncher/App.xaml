<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CopilotLauncher.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Default card border thickness (1px). The Copilot CLI theme bumps
                 this to 2px via ThemeManager so the bright pink stroke is more
                 visible against the dark backdrop. -->
            <Thickness x:Key="CardBorderThickness">1</Thickness>
            <!-- Filter checkbox label font size — defaults to the Fluent body
                 size; ThemeManager bumps this in copilotCli mode so the label
                 text reads at the same scale as the cards around it. -->
            <x:Double x:Key="FilterCheckBoxFontSize">14</x:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
