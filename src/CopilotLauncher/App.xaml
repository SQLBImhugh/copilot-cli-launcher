<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CopilotLauncher.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Default card border thickness (1px). ThemeManager bumps this
                 to 2px for the Copilot CLI palette and in Windows High
                 Contrast so card outlines stay readable. -->
            <Thickness x:Key="CardBorderThickness">1</Thickness>
            <!-- Filter checkbox label font size — defaults to the Fluent body
                 size; ThemeManager bumps this in copilotCli mode so the label
                 text reads at the same scale as the cards around it. -->
            <x:Double x:Key="FilterCheckBoxFontSize">14</x:Double>
            <!-- Heading font family — applied inline on page titles + Settings
                 section subheadings. ThemeManager swaps this to the VT323
                 pixel font in copilotCli mode; everywhere else (including
                 body / control text in copilotCli) stays in the standard
                 Fluent UI font (or Consolas in copilotCli mode). -->
            <FontFamily x:Key="HeadingFontFamily">Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI</FontFamily>
            <!-- Body font family — applied via FontFamily="{ThemeResource ...}"
                 on each Page root + MainWindow root grid so it propagates by
                 visual-tree inheritance to every TextBlock that doesn't set
                 its own FontFamily (which is most of them — Fluent's
                 BodyTextBlockStyle / SubtitleTextBlockStyle / etc. don't set
                 a FontFamily setter). ThemeManager swaps to Consolas in
                 copilotCli mode. -->
            <FontFamily x:Key="BodyFontFamily">Segoe UI Variable Text, Segoe UI</FontFamily>
            <!-- Page title font size — defaults to the Fluent
                 TitleLargeTextBlockStyle equivalent (40px). Compact mode
                 swaps this to 22px so the title doesn't dominate a 300px-wide
                 mini window. -->
            <x:Double x:Key="PageTitleFontSize">40</x:Double>
            <!-- Section subheading font size (Settings cards). Defaults to
                 the SubtitleTextBlockStyle 20px; compact reduces to 14. -->
            <x:Double x:Key="SectionTitleFontSize">20</x:Double>
            <!-- Page padding tuple — Sessions/Shortcuts/etc use a Thickness
                 for their root Grid Padding. ThemeManager replaces this with
                 a tighter value in compact mode so the chrome doesn't eat
                 the available width. -->
            <Thickness x:Key="PagePadding">32,24,32,16</Thickness>
        </ResourceDictionary>
    </Application.Resources>
</Application>
