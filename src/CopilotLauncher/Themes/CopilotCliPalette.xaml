<?xml version="1.0" encoding="utf-8"?>
<!--
    Copilot CLI palette overrides. Merged into Application.Resources at
    runtime by ThemeManager when the user picks the "Copilot CLI" theme.
    Removed when they switch back to system / light / dark.

    Colors sampled from the GitHub Copilot CLI welcome banner:
      bg    #171717  (near-black, slight grey)
      cyan  #0099CC  (primary accent — letters, focus, selection)
      pink  #CC66CC  (secondary accent — borders, callouts)
      green #30C868  (success / positive accents)
      text  #FFFFFF / #CCCCCC

    Keys here intentionally shadow the built-in Fluent dark theme keys
    used by ThemeResource lookups across our pages (Sessions, Shortcuts,
    Briefing, Settings, NewShortcut). The runtime applies this dict on
    top of ElementTheme.Dark, so brushes we *don't* override fall back
    to the standard dark theme defaults — meaning we don't have to enumerate
    every single brush in the WinUI control gallery.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Page / window backgrounds -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#171717"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="#171717"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="#1B1B1B"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="#1F1F1F"/>

    <!-- Card surfaces (used by every page's Border-with-rounded-corners) -->
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#1B1B1B"/>
    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#222222"/>
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#3A2640"/>
    <SolidColorBrush x:Key="CardStrokeColorDefaultSolidBrush" Color="#3A2640"/>

    <!-- Subtle fills (status bars, hover backgrounds) -->
    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="#1FCC66CC"/>
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="#1A1A1A"/>

    <!-- Control fills (Button/ComboBox/TextBox backgrounds) -->
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#222222"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#3A2640"/>
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="#3A2640"/>

    <!-- Accent (cyan = primary brand color from the CLI banner) -->
    <Color x:Key="SystemAccentColor">#FF0099CC</Color>
    <Color x:Key="SystemAccentColorDark1">#FF0088B8</Color>
    <Color x:Key="SystemAccentColorDark2">#FF00779F</Color>
    <Color x:Key="SystemAccentColorLight1">#FF0AAFE0</Color>
    <Color x:Key="SystemAccentColorLight2">#FF22BCEE</Color>
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#0099CC"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#0AAFE0"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#007AA8"/>
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="#404040"/>
    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#22BCEE"/>
    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#0AAFE0"/>
    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush" Color="#0099CC"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#999999"/>
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="#5C5C5C"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="#A0A0A0"/>

    <!-- Focus / selection -->
    <SolidColorBrush x:Key="FocusStrokeColorOuterBrush" Color="#0AAFE0"/>
    <SolidColorBrush x:Key="FocusStrokeColorInnerBrush" Color="#171717"/>

    <!-- System-status accents — pink/green for our chip/badge surfaces -->
    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="#30C868"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="#CC66CC"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="#F2C94C"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="#E0617A"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="#9A9A9A"/>
    <SolidColorBrush x:Key="SystemFillColorSolidNeutralBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="SystemFillColorSuccessBackgroundBrush" Color="#1F30C868"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBackgroundBrush" Color="#1FCC66CC"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBackgroundBrush" Color="#1FF2C94C"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBackgroundBrush" Color="#1FE0617A"/>

    <!-- NavigationView (left rail) — pink-tinted highlight on the selected
         item makes the active page obvious against the dark surface. -->
    <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#0AAFE0"/>
</ResourceDictionary>
