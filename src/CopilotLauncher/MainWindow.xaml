<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CopilotLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:pages="using:CopilotLauncher.Pages"
    Title="Copilot CLI Launcher">

    <Grid x:Name="WindowRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title-bar row split into:
             Col 0  AppTitleBar drag region (passed to SetTitleBar). Holds
                    the title TextBlock; user can drag anywhere inside.
             Col 1  Theme + Compact icon buttons. NOT inside the SetTitleBar
                    element so clicks land on the buttons rather than being
                    eaten by the title-bar drag hit-test (per rubber-duck
                    pass — interactive controls must live OUTSIDE the
                    SetTitleBar region in WinUI 3 1.6).
             Col 2  138px reserved for the system min/max/close buttons that
                    Windows draws on top of our content. -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="138"/>
            </Grid.ColumnDefinitions>

            <Grid x:Name="AppTitleBar" Grid.Column="0" Background="{ThemeResource SubtleFillColorTransparentBrush}">
                <TextBlock Text="Copilot CLI Launcher"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.8"/>
            </Grid>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button x:Name="ThemeButton"
                        AutomationProperties.AutomationId="TitleBarThemeButton"
                        AutomationProperties.Name="Switch theme"
                        ToolTipService.ToolTip="Switch theme"
                        Background="{ThemeResource SubtleFillColorTransparentBrush}"
                        BorderBrush="{ThemeResource SubtleFillColorTransparentBrush}"
                        Padding="10,0"
                        VerticalAlignment="Stretch">
                    <muxc:FontIcon Glyph="&#xE790;" FontSize="14"/>
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <muxc:RadioMenuFlyoutItem x:Name="ThemeSystemItem"  Text="Follow system" GroupName="LauncherTheme" Tag="system"     Click="OnThemeMenuItemClick"/>
                            <muxc:RadioMenuFlyoutItem x:Name="ThemeLightItem"   Text="Light"         GroupName="LauncherTheme" Tag="light"      Click="OnThemeMenuItemClick"/>
                            <muxc:RadioMenuFlyoutItem x:Name="ThemeDarkItem"    Text="Dark"          GroupName="LauncherTheme" Tag="dark"       Click="OnThemeMenuItemClick"/>
                            <muxc:RadioMenuFlyoutItem x:Name="ThemeCopilotItem" Text="Copilot CLI"   GroupName="LauncherTheme" Tag="copilotCli" Click="OnThemeMenuItemClick"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <Button x:Name="CompactButton"
                        AutomationProperties.AutomationId="TitleBarCompactButton"
                        AutomationProperties.Name="Toggle compact mode"
                        ToolTipService.ToolTip="Toggle compact mode"
                        Click="OnCompactToggleClick"
                        Background="{ThemeResource SubtleFillColorTransparentBrush}"
                        BorderBrush="{ThemeResource SubtleFillColorTransparentBrush}"
                        Padding="10,0"
                        VerticalAlignment="Stretch">
                    <muxc:FontIcon x:Name="CompactGlyph" Glyph="&#xE73F;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <muxc:NavigationView Grid.Row="1"
            x:Name="NavView"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="NavView_SelectionChanged">

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Tag="sessions" Content="Sessions" AutomationProperties.AutomationId="NavSessions">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE823;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem Tag="shortcuts" Content="Shortcuts" AutomationProperties.AutomationId="NavShortcuts">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE734;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem Tag="newshortcut" Content="New Shortcut" AutomationProperties.AutomationId="NavNewShortcut">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE710;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem Tag="briefing" Content="Briefing" AutomationProperties.AutomationId="NavBriefing">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE7C3;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem Tag="settings" Content="Settings" AutomationProperties.AutomationId="NavSettings">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE713;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
