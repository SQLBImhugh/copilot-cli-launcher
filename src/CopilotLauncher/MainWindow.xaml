<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CopilotLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:pages="using:CopilotLauncher.Pages"
    Title="Copilot CLI Launcher">

    <Grid x:Name="WindowRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom drag area for the title bar. ExtendsContentIntoTitleBar=true
             means we own this 32px strip; SetTitleBar(AppTitleBar) makes the
             whole strip a draggable region. Leave the right ~138px clear so
             the system min/max/close buttons aren't covered (they're drawn
             by Windows on top of our content). -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="{ThemeResource SubtleFillColorTransparentBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="138"/>  <!-- system caption buttons -->
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Copilot CLI Launcher"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.8"/>
        </Grid>

        <muxc:NavigationView Grid.Row="1"
            x:Name="NavView"
            AutomationProperties.AutomationId="ShellNavigationView"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="NavView_SelectionChanged">

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Tag="sessions" Content="Sessions" AutomationProperties.AutomationId="NavSessions">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE823;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem Tag="shortcuts" Content="Shortcuts" AutomationProperties.AutomationId="NavShortcuts">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE734;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem Tag="newshortcut" Content="New Shortcut" AutomationProperties.AutomationId="NavNewShortcut">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE710;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem Tag="briefing" Content="Briefing" AutomationProperties.AutomationId="NavBriefing">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE7C3;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

                <!-- Settings sits with the rest of the nav items now (was
                     auto-rendered at the bottom via IsSettingsVisible) so the
                     gear is reachable without scrolling on small heights. -->
                <muxc:NavigationViewItem Tag="settings" Content="Settings" AutomationProperties.AutomationId="NavSettings">
                    <muxc:NavigationViewItem.Icon>
                        <muxc:FontIcon Glyph="&#xE713;"/>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
